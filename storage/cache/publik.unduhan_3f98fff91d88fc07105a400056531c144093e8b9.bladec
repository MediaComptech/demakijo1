 <i class='fas fa-file-pdf text-danger me-2'></i> <?php echo \htmlentities($item->judul??'', ENT_QUOTES, 'UTF-8', false); ?>

 </td>
 <td><?php echo \htmlentities($item->created_at->format('d M Y')??'', ENT_QUOTES, 'UTF-8', false); ?></td>
