 <a href='#' class='btn btn-primary btn-sm rounded-pill px-3 fw-bold shadow-sm'><i class='fas fa-download me-1'></i> Unduh</a>
 </td>
 </tr>
 <?php endforeach; if ($__empty_1): ?>
 <tr>
